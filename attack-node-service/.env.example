# HTTP control API listen address
HTTP_ADDR=0.0.0.0:2005

# RabbitMQ connection and status event queue
RABBITMQ_URL=amqp://<user>:<password>@<rabbitmq-host>:5672/
RABBITMQ_ATTACK_STATUS_QUEUE=attack.status.events

# Attack command definitions and script working directory
ATTACK_COMMANDS_FILE=commands.json
ATTACK_SCRIPT_DIR=.
