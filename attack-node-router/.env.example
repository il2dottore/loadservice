# This service is a RabbitMQ consumer and producer; it does not expose an HTTP API.
# Attack-node HTTP settings are configured in attack-node-service/.env.example.
# RabbitMQ connection and event queues
RABBITMQ_URL=amqp://<user>:<password>@<rabbitmq-host>:5672/
RABBITMQ_ATTACK_QUEUE=attack.events
RABBITMQ_ATTACK_STATUS_QUEUE=attack.status.events
